# Define function to write state history to file
function write_state_history_to_file(file_path::String, state::State, edit_type::String)
    if edit_type == "init"
        file = open(file_path, "w")
    else
        file = open(file_path, "a")
    end
    write(file, string(state))
    close(file)
end

